console.log('number' + 3 + 3)       // number33, тому що відбувся конкатенейшен змінної стрінг з двома цифрами
console.log(null + 3);      //3, тому що джаваскріпт все зводить до типу намбер, в цьому випадку звела null до 0
console.log(5 && "qwerty");     //qwerty, тому що в циклі з оператором && повертається останнє обчислене значення 
console.log(+'40' + +'2' + "hillel");        //42hillel, тому що спершу унарний плюс привів стрінгу 40 і 2 до чисел 40 + 2 -> вийшло 42, потім відбулась конкатинація з стрінгою
console.log('10' - 5 === 6);     //false, тому що '10'-5 = 5 -> джаваскріпт привело все до намбер. 5 не строго дорівнює 6 через різне значення.
console.log(true + false);      //1, тому що джаваскріпт привела булеві значення до намбера
console.log('4px' - 3);      //Nan, тому що від стрінги неможливо відняти цифру 3
console.log('4' - 3);      //1, через зведення всього до типу намбер
console.log('6' + 3 ** 0);      //61, тут є правоасоціативна операція - спочатку 3 ** 0 = 1; потім '6' + 1 = 61 - через конкатинацію
console.log(12 / '6');      // 2, приведення до намбер
console.log('10' + (5 === 6));      //10false, спочатку обчислюємо 5===6 - false, потім конкатинацію
console.log(null == '');      // false, тому що null може дорівнювати лише null чи undefined, а не пустій строці
console.log(3 ** (9 / 3));      //27, тут є правоасоціативна операція - спочатку 9/3 = 3, потім 3**3 = 27
console.log(!!'false' == !!'true');      //true, оскільки !!'false' = true  і !!'true' = true; !! - швидко переводить тип стрінг до булевого значення
console.log(0 || '0' && 1);      //1.'0' - перше true в циклі ||. потім виконуємо '0' && 1 - буде 1, тому що в циклі && повертається останнє обчислюване значення
console.log((+null == false) < 1);      //false, тому що +null = 0, 0 == false = true. true приводиться до 1, 1<1 = false
console.log(false && true || true);      //true, тому що цикл && зупинився на першому false. false || true буде true
console.log(false && (false || true));      //false, тому що цикл && зупинився на першому false
console.log((+null == false) < 1 ** 5);      //false, тому що (+null == false) = true, true зводиться до 1, 1 < 1 ** 5 = 1 < 1 = false